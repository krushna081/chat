# Resend API key (required)
RESEND_API_KEY=your_resend_api_key_here

# From address to use for outgoing emails (use your verified domain)
EMAIL_FROM="SecureChat <onboarding@krushna081.online>"

# Optional: during development, Resend test keys only allow sending to your account email
# Set this to your verified account email to receive test emails locally
RESEND_TEST_EMAIL=krushnacjadhav0807@gmail.com

# App environment
NODE_ENV=development
# Client: Set to 'false' to disable encryption and send plaintext messages
# (create a .env in client/ or set VITE_USE_ENCRYPTION in your dev env)
VITE_USE_ENCRYPTION=true
